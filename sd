/* ===== TOAST WIDGET ===== */
#toastCont{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:10px}
.toast{padding:14px 20px;border-radius:var(--r2);font-size:14px;font-weight:600;display:flex;align-items:center;gap:10px;box-shadow:0 10px 30px rgba(0,0,0,0.4);animation:toastIn .3s forwards}
@keyframes toastIn{from{transform:translateX(50px);opacity:0}to{transform:translateX(0);opacity:1}}

/* ===== INTEGRAÇÃO MÓDULO 1: CHAT AI FLUTUANTE ===== */
#aiFloatingWidget {
  position:fixed;bottom:24px;left:24px;z-index:1900;
  width:60px;height:60px;border-radius:50%;
  background:linear-gradient(135deg, var(--yellow), #ffc200);
  box-shadow:0 8px 32px rgba(255,215,0,0.3);
  display:flex;align-items:center;justify-content:center;
  color:#000;font-size:26px;border:none;transition:transform .2s;
}
#aiFloatingWidget:hover { transform:scale(1.08); }
.ai-box {
  position:fixed;bottom:96px;left:24px;z-index:1901;
  width:360px;height:480px;background:#0d0d0d;
  border:1px solid var(--border2);border-radius:16px;
  box-shadow:0 12px 40px rgba(0,0,0,0.6);
  display:none;flex-direction:column;overflow:hidden;
}
.ai-box.open { display:flex; }
.ai-header {
  background:#000;padding:16px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:10px;
}
.ai-avatar {
  width:36px;height:36px;border-radius:50%;
  background:var(--yellow);color:#000;
  display:flex;align-items:center;justify-content:center;font-size:18px;
}
.ai-title { font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:900;color:#fff; }
.ai-close { margin-left:auto;background:none;border:none;color:var(--muted);font-size:18px; }
.ai-messages { flex:1;padding:16px;overflow-y:auto;display:flex;flex-direction:column;gap:12px; }
.ai-msg { padding:10px 14px;border-radius:14px;font-size:13px;line-height:1.5;max-width:85%;word-break:break-word; }
.ai-msg.bot { background:var(--card);border:1px solid var(--border);align-self:flex-start;border-bottom-left-radius:4px;color:#fff; }
.ai-msg.user { background:var(--yellow);color:#000;font-weight:600;align-self:flex-end;border-bottom-right-radius:4px; }
.ai-thinking { display:flex;align-items:center;gap:4px;color:var(--muted);font-size:12px;padding:6px;align-self:flex-start; }
.ai-thinking span { width:5px;height:5px;border-radius:50%;background:var(--yellow);animation:aiBlink 1.4s infinite both; }
.ai-thinking span:nth-child(2) { animation-delay:.2s; }
.ai-thinking span:nth-child(3) { animation-delay:.4s; }
@keyframes aiBlink { 0%,80%,100% { opacity:.2; } 40% { opacity:1; } }
.ai-footer { padding:12px;background:#050505;border-top:1px solid rgba(255,255,255,0.05);display:flex;gap:8px; }
.ai-input { flex:1;background:var(--card);border:1px solid var(--border);border-radius:20px;padding:8px 16px;color:#fff;font-size:13px;outline:none; }
.ai-send { width:36px;height:36px;border-radius:50%;background:var(--yellow);border:none;color:#000;display:flex;align-items:center;justify-content:center;font-size:14px; }

