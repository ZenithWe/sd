.stat-card-n{font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:900;color:var(--yellow);line-height:1}
.stat-card-l{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-top:4px}
.data-table{width:100%;border-collapse:collapse;font-size:14px;text-align:left}
.data-table th{padding:12px 16px;color:var(--muted);font-weight:600;border-bottom:2px solid rgba(255,255,255,0.05)}
.data-table td{padding:14px 16px;color:var(--text);border-bottom:1px solid rgba(255,255,255,0.03)}
.data-table tr:hover td{background:rgba(255,215,0,0.01)}
