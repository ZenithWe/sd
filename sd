// ============ MÓDULO 3 INTEGRAÇÃO: CONSTRUTOR BR CODE E GERAÇÃO REAL DE QR PIX ============
let globalPixCopiaCola = "";

function buildPixPayload(key, amount, name) {
  function field(id, value) {
    const len = String(value.length).padStart(2, '0');
    return id + len + value;
  }
  const merchantAccountInfo = field('00', 'BR.GOV.BCB.PIX') + field('01', key);
  const merchantAccountInfoField = field('26', merchantAccountInfo);
  const merchantCategoryCode = field('52', '0000');
  const transactionCurrency = field('53', '986');
  const transactionAmount = field('54', amount);
  const countryCode = field('58', 'BR');
  const merchantName = field('59', name.substring(0, 25));
  const merchantCity = field('60', 'SAO PAULO');
  const additionalDataField = field('62', field('05', '***'));
  
  let payload = field('00', '01') + merchantAccountInfoField + merchantCategoryCode + 
                transactionCurrency + transactionAmount + countryCode + merchantName + 
                merchantCity + additionalDataField + '6304';
  
  // Cálculo CRC16 simplificado padrão BR Code
  let crc = 0xFFFF;
  for (let c = 0; c < payload.length; c++) {
    crc ^= payload.charCodeAt(c) << 8;
    for (let i = 0; i < 8; i++) {
      if (crc & 0x8000) crc = (crc << 1) ^ 0x1021;
      else crc <<= 1;
    }
  }
  crc = (crc & 0xFFFF).toString(16).toUpperCase().padStart(4, '0');
  return payload + crc;
}

function processOrder() {
  const name = document.getElementById('co-name').value.trim();
  const email = document.getElementById('co-email').value.trim();
  const cpf = document.getElementById('co-cpf').value.trim();
  const discord = document.getElementById('co-discord').value.trim();

  if(!name || !email || !cpf || !discord) {
    toast('Preencha todas as informações obrigatórias para prosseguir.', 'error');
    return;
  }

  const orderId = 'BG-' + String(Date.now()).slice(-6);
  const total = cart.reduce((acc, item) => acc + parseFloat(item.price), 0);
  
  const order = {
    id: orderId,
    userId: DB.currentUser() ? DB.currentUser().id : null,
    customer: name,
    email: email,
    cpf: cpf,
    discord: discord,
    mode: document.getElementById('co-mode').value,
    items: cart.map(i=>i.name).join(', '),
    total: total.toFixed(2),
    date: new Date().toLocaleDateString('pt-BR'),
    status: 'pending'
  };

  DB.addOrder(order);
  document.getElementById('successOrderNum').textContent = '#' + orderId;
  
  // Limpeza de Estado do Carrinho
  cart = [];
  sessionStorage.removeItem('bg_cart');
  updateCartUI();

  // Ativação do Módulo de Geração Pix via API Pública do qrserver (padrão pix.ae livre)
  showPage('success');
  
  const pixKey = DB.siteTexts().pixKey;
  globalPixCopiaCola = buildPixPayload(pixKey, order.total, 'BEGINNING GAME');
  
  document.getElementById('pixCopiaColaText').textContent = globalPixCopiaCola;
  
  const imgUrl = `https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=${encodeURIComponent(globalPixCopiaCola)}&margin=4`;
  const imgEl = document.getElementById('pixGeneratedImg');
  const loaderEl = document.getElementById('pixQrLoading');
  const statusEl = document.getElementById('pixPayloadStatus');
  
  imgEl.src = imgUrl;
  imgEl.onload = () => {
    loaderEl.style.display = 'none';
    imgEl.style.display = 'block';
    statusEl.textContent = '✓ BR Code Pix válido gerado';
    statusEl.style.color = '#00c853';
  };
  imgEl.onerror = () => {
    loaderEl.textContent = '⚠ Erro na renderização do QR Code — utilize a cópia textual';
    loaderEl.style.color = '#D90429';
  };
}

function copyPixCopiaCola() {
  if(!globalPixCopiaCola) return;
  navigator.clipboard.writeText(globalPixCopiaCola).then(()=>{
    toast('Código Pix Copiado para área de transferência!', 'success');
  });
}

