// ============ MÓDULO 1 INTEGRAÇÃO: CHAT INTELIGENTE COM Claude (SIMULADO / EXTENSÍVEL) ============
function toggleAiBox() {
  document.getElementById('aiBox').classList.toggle('open');
}

function sendAiMessage() {
  const input = document.getElementById('aiInput');
  const query = input.value.trim();
  if(!query) return;

  const msgsBox = document.getElementById('aiMessages');
  
  // Imprime Mensagem do Usuário
  const userDiv = document.createElement('div');
  userDiv.className = 'ai-msg user';
  userDiv.textContent = query;
  msgsBox.appendChild(userDiv);
  
  input.value = '';
  msgsBox.scrollTop = msgsBox.scrollHeight;

  // Renderiza Animação Pensando
  const thinkingDiv = document.createElement('div');
  thinkingDiv.className = 'ai-thinking';
  thinkingDiv.id = 'ai-thinking-temp';
  thinkingDiv.innerHTML = `Processando com Claude<span></span><span></span><span></span>`;
  msgsBox.appendChild(thinkingDiv);
  msgsBox.scrollTop = msgsBox.scrollHeight;

  // Lógica Claude via Anthropic API (Fallback Estruturado)
  setTimeout(() => {
    document.getElementById('ai-thinking-temp').remove();
    
    let reply = "Entendi! Para melhorar o seu rendimento no Fortnite competitivo, recomendo focar em mapas de Creative voltados a Piece Control e fazer VOD Review de suas mortes no Arena/Fncs.";
    
    // Respostas Contextuais Básicas
    const qLower = query.toLowerCase();
    if(qLower.includes('plano') || qLower.includes('preço') || qLower.includes('comprar')) {
      reply = "Temos 3 planos estruturais de Mentoria (Basic, Pro e Elite), além de E-books de apoio em nossa Home Page. Adicione ao carrinho para iniciar seu treinamento!";
    } else if(qLower.includes('sensibilidade') || qLower.includes('sens')) {
      reply = "A sensibilidade ideal varia, mas a maioria dos Pro Players usa entre 400 a 800 DPI com sensibilidade in-game variando de 6% a 10%. O mais importante é a consistência muscular!";
    } else if(qLower.includes('unreal') || qLower.includes('rank')) {
      reply = "Para subir do Champion ao Unreal você precisa de consistência e foco em posicionamento (placement points) no late game, evitando lutas desnecessárias no mid-game.";
    }

    const botDiv = document.createElement('div');
    botDiv.className = 'ai-msg bot';
    botDiv.textContent = reply;
    msgsBox.appendChild(botDiv);
    msgsBox.scrollTop = msgsBox.scrollHeight;
  }, 1000);
}

// ============ INICIALIZADOR GERAL AO CARREGAR PÁGINA ============
function init() {
  applySiteTexts();
  renderPlans();
  updateCartUI();
  updateNavForUser();
  
  // Observador para disparar animação de contagem ao rolar a página
  const observer = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting) {
        animateCounters();
        observer.disconnect();
      }
    });
  }, {threshold: 0.2});
  
  const counterSection = document.getElementById('counter');
  if(counterSection) observer.observe(counterSection);
}

window.onload = init;
</script>
