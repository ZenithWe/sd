.panel-name{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:900;color:#fff}
.panel-role{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:2px}
.panel-nav{display:flex;flex-direction:column;gap:4px}
.admin-nav-item, .client-nav-item{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:var(--r2);font-size:14px;font-weight:600;color:var(--muted2);transition:all .2s}
.admin-nav-item:hover, .client-nav-item:hover{color:var(--yellow);background:rgba(255,215,0,0.04)}
.admin-nav-item.active, .client-nav-item.active{color:#000;background:var(--yellow)}
.client-content, .admin-content{background:#0d0d0d;border:1px solid var(--border);border-radius:20px;padding:32px;min-height:500px}
.client-section, .admin-section{display:none}
