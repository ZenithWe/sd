function savePlan() {
  const id = document.getElementById('planEditId').value;
  const name = document.getElementById('planName').value.trim();
  const price = document.getElementById('planPrice').value.trim();
  const color = document.getElementById('planColor').value;
  const desc = document.getElementById('planDesc').value.trim();
  const features = document.getElementById('planFeatures').value.split('\n').filter(f=>f.trim());

  if(!name || !price) { toast('Nome e Preço obrigatórios', 'error'); return; }

  let plans = DB.plans();
  if(id) {
    plans = plans.map(p=> p.id === parseInt(id) ? {id:p.id, name, price, color, desc, features, active:p.active} : p);
  } else {
    plans.push({ id: Date.now(), name, price, color, desc, features, active:true });
  }
  
  DB.savePlans(plans);
  closeModal('planModal');
  toast('Plano salvo!', 'success');
  renderAdmin();
  renderPlans();
}

function openCategoryModal() {
  document.getElementById('categoryName').value = '';
  document.getElementById('categoryModal').classList.add('open');
}

function saveCategory() {
  const name = document.getElementById('categoryName').value.trim();
  if(!name) return;
  const slug = name.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-8]/g, '-');
  
  const cats = DB.categories();
  if(cats.find(c=>c.slug === slug)) { toast('Categoria já existe', 'error'); return; }
  
  cats.push({slug, name});
  DB.saveCategories(cats);
  closeModal('categoryModal');
  toast('Categoria salva', 'success');
  renderAdmin();
  renderPlans();
}

function deleteCategory(slug) {
  let cats = DB.categories();
  cats = cats.filter(c=>c.slug !== slug);
  DB.saveCategories(cats);
  renderAdmin();
  renderPlans();
}

