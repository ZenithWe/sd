// ============ EVENTOS DO CARRINHO DE COMPRAS ============
function toggleCart() {
  document.getElementById('cartOverlay').classList.toggle('open');
  document.getElementById('cartSidebar').classList.toggle('open');
}

function addToCart(id, type) {
  let item = null;
  if(type === 'plan') {
    item = DB.plans().find(p=>p.id===id);
  } else {
    item = DB.digitalProducts().find(d=>d.id===id);
  }
  if(!item) return;

  if(cart.find(i=>i.id===id && i.type===type)){
    toast('Este item já está em seu carrinho!', 'info');
    toggleCart();
    return;
  }

  cart.push({id: item.id, name: item.name, price: item.price, type: type});
  saveCart();
  toast('Item adicionado ao carrinho!', 'success');
  toggleCart();
}

function addMockupToCart() {
  addToCart(2, 'plan');
}

function removeFromCart(idx) {
  cart.splice(idx, 1);
  saveCart();
}

function updateCartUI() {
  document.getElementById('cartCount').textContent = cart.length;
  const container = document.getElementById('cartItemsContainer');
  if(!container) return;
  container.innerHTML = '';

  let total = 0;
  if(cart.length === 0) {
    container.innerHTML = '<div class="cart-empty">Seu carrinho está vazio.</div>';
  } else {
    cart.forEach((item, idx)=>{
      total += parseFloat(item.price);
