/* ===== CLIENT & ADMIN PANEL DESIGN ===== */
.panel-layout{display:grid;grid-template-columns:260px 1fr;gap:32px;align-items:flex-start}
.panel-sidebar{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:24px}
