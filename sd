<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>BG - Beginning Game | Mentorias e VOD Reviews Fortnite</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css"/>
<style>
/* =====================================================================
   BG - Beginning Game | Site Completo + Módulos Complementares
   Cores: #000 Preto | #FFD700 Amarelo | #D90429 Vermelho
   ===================================================================== */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --black:#000000;--yellow:#FFD700;--red:#D90429;
  --yellow2:#FFC200;--red2:#ff0033;
  --dark:#0a0a0a;--card:#111;--card2:#181818;--card3:#222;
  --border:rgba(255,215,0,0.15);--border2:rgba(255,215,0,0.3);
  --text:#f0f0f0;--muted:#888;--muted2:#bbb;
  --green:#00c853;--blue:#1e90ff;
  --r:12px;--r2:8px;
}
html{scroll-behavior:smooth}
body{background:var(--dark);font-family:'Barlow',sans-serif;color:var(--text);overflow-x:hidden}
a{text-decoration:none;color:inherit}
img{max-width:100%}
.container{max-width:1200px;margin:0 auto;padding:0 24px}
.hidden{display:none!important}

code,pre{font-family:'JetBrains Mono',monospace}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:#111}
::-webkit-scrollbar-thumb{background:var(--yellow);border-radius:3px}

/* ===== CURSOR ===== */
*{cursor:default}
a,button,[onclick],.faq-q,.admin-nav-item,.client-nav-item{cursor:pointer}

/* ===== PAGES ===== */
.page{display:none}
.page.active{display:block}

/* ===== NAVBAR ===== */
#navbar{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(0,0,0,0.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);transition:all .3s}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:68px;max-width:1200px;margin:0 auto;padding:0 24px}
.nav-logo{display:flex;align-items:center;gap:10px;font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:900;letter-spacing:1px}
.nav-logo .bg-flag{width:36px;height:28px;border-radius:4px;overflow:hidden;display:flex;flex-direction:column;border:1px solid rgba(255,255,255,0.1)}
.nav-logo .flag-b{flex:1;background:#000}
.nav-logo .flag-y{flex:1;background:#FFD700}
.nav-logo .flag-r{flex:1;background:#D90429}
.nav-logo span{color:var(--yellow)}
.nav-logo em{color:#fff;font-style:normal}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{font-size:15px;font-weight:500;color:var(--muted2);transition:color .2s;position:relative}
.nav-links a:hover{color:var(--yellow)}
.nav-links a.active{color:var(--yellow)}
.nav-actions{display:flex;align-items:center;gap:10px}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border:none;border-radius:var(--r2);font-family:'Barlow',sans-serif;font-size:14px;font-weight:600;transition:all .2s;padding:10px 20px;letter-spacing:.3px}
.btn-yellow{background:var(--yellow);color:#000}
.btn-yellow:hover{background:var(--yellow2);transform:translateY(-1px);box-shadow:0 6px 20px rgba(255,215,0,0.3)}
.btn-red{background:var(--red);color:#fff}
.btn-red:hover{background:var(--red2);transform:translateY(-1px);box-shadow:0 6px 20px rgba(217,4,41,0.4)}
.btn-outline{background:transparent;color:var(--yellow);border:1.5px solid var(--yellow)}
.btn-outline:hover{background:rgba(255,215,0,0.1)}
.btn-dark{background:var(--card2);color:var(--text);border:1px solid var(--border)}
.btn-dark:hover{background:var(--card3);border-color:var(--border2)}
.btn-lg{padding:14px 32px;font-size:16px;border-radius:var(--r)}
.btn-xl{padding:18px 40px;font-size:18px;border-radius:var(--r);font-weight:700}
.btn-full{width:100%}
.cart-btn{position:relative}
.cart-count{position:absolute;top:-6px;right:-6px;width:18px;height:18px;background:var(--red);border-radius:50%;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;color:#fff}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;padding:4px}
.hamburger span{display:block;width:24px;height:2px;background:var(--text);border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;top:68px;left:0;right:0;background:#000;border-bottom:1px solid var(--border);padding:20px 24px;flex-direction:column;gap:16px;z-index:999}
.mobile-menu.open{display:flex}
.mobile-menu a{font-size:18px;font-weight:500;color:var(--muted2);padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.05)}

/* ===== HERO ===== */
#hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding-top:68px}
.hero-bg{position:absolute;inset:0;background:#000}
.hero-bg::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 60% 50%,rgba(255,215,0,0.08) 0%,transparent 60%)}
.hero-bg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 40% 40% at 80% 80%,rgba(217,4,41,0.1) 0%,transparent 60%)}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,215,0,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,215,0,0.03) 1px,transparent 1px);background-size:60px 60px}
.hero-content{position:relative;z-index:2;max-width:1200px;margin:0 auto;padding:80px 24px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,215,0,0.1);border:1px solid var(--border2);border-radius:50px;padding:6px 16px;font-size:13px;font-weight:600;color:var(--yellow);margin-bottom:20px}
.hero-badge i{font-size:14px}
.hero-title{font-family:'Barlow Condensed',sans-serif;font-size:clamp(56px,8vw,92px);font-weight:900;line-height:.95;letter-spacing:-1px;text-transform:uppercase;margin-bottom:24px}
.hero-title .line1{color:#fff}
.hero-title .line2{color:var(--yellow)}
.hero-title .line3{color:var(--red);-webkit-text-stroke:2px var(--red);-webkit-text-fill-color:transparent}
.hero-desc{font-size:17px;color:var(--muted2);line-height:1.7;margin-bottom:32px;max-width:480px}
.hero-ctas{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:40px}
.hero-stats{display:flex;gap:28px}
.hstat{text-align:center}
.hstat-n{font-family:'Barlow Condensed',sans-serif;font-size:36px;font-weight:900;color:var(--yellow);line-height:1}
.hstat-l{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:2px}
.hero-visual{position:relative;display:flex;align-items:center;justify-content:center}
.hero-card-mockup{background:var(--card);border:1px solid var(--border2);border-radius:20px;padding:32px;position:relative;overflow:hidden;width:100%;max-width:440px}
.hero-card-mockup::before{content:'';position:absolute;top:-60px;right:-60px;width:200px;height:200px;background:radial-gradient(circle,rgba(255,215,0,0.15),transparent 70%)}
.hero-card-mockup::after{content:'';position:absolute;bottom:-40px;left:-40px;width:150px;height:150px;background:radial-gradient(circle,rgba(217,4,41,0.12),transparent 70%)}
.mockup-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(217,4,41,0.15);border:1px solid rgba(217,4,41,0.3);border-radius:50px;padding:5px 12px;font-size:12px;font-weight:700;color:var(--red);margin-bottom:16px;text-transform:uppercase;letter-spacing:.5px}
.mockup-plan-name{font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:900;color:#fff;margin-bottom:8px}
.mockup-price{font-family:'Barlow Condensed',sans-serif;font-size:52px;font-weight:900;color:var(--yellow);line-height:1;margin-bottom:20px}
.mockup-price span{font-size:22px;color:var(--muted2)}
.mockup-features{display:flex;flex-direction:column;gap:8px;margin-bottom:24px}
.mockup-feat{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--muted2)}
.mockup-feat i{color:var(--yellow);font-size:16px;flex-shrink:0}
.float-badge{position:absolute;background:var(--card2);border:1px solid var(--border2);border-radius:12px;padding:10px 14px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px}
.float-1{top:-16px;right:20px;color:var(--yellow);animation:float 3s ease-in-out infinite}
.float-2{bottom:-16px;left:20px;color:var(--muted2);animation:float 3s ease-in-out .5s infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}

/* ===== SECTION COMMON ===== */
section{padding:80px 0}
.sec-header{text-align:center;margin-bottom:56px}
.sec-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(255,215,0,0.08);border:1px solid var(--border);border-radius:50px;padding:5px 14px;font-size:12px;font-weight:700;color:var(--yellow);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px}
.sec-title{font-family:'Barlow Condensed',sans-serif;font-size:clamp(36px,5vw,56px);font-weight:900;text-transform:uppercase;line-height:1;margin-bottom:16px}
.sec-title span{color:var(--yellow)}
.sec-desc{font-size:17px;color:var(--muted2);max-width:560px;margin:0 auto;line-height:1.7}
.divider{width:60px;height:3px;background:linear-gradient(90deg,var(--yellow),var(--red));border-radius:2px;margin:16px auto 0}

/* ===== PLANS ===== */
#plans{background:#000}
.plans-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.plan-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:32px;position:relative;overflow:hidden;transition:all .3s}
.plan-card:hover{transform:translateY(-6px);border-color:var(--border2);box-shadow:0 20px 60px rgba(255,215,0,0.08)}
.plan-card.featured{border-color:rgba(217,4,41,0.5);box-shadow:0 0 40px rgba(217,4,41,0.12)}
.plan-card .glow{position:absolute;top:0;left:0;right:0;height:3px}
.plan-blue .glow{background:linear-gradient(90deg,#1e90ff,#00bfff)}
.plan-green .glow{background:linear-gradient(90deg,#00c853,#69f0ae)}
.plan-red .glow{background:linear-gradient(90deg,var(--red),#ff6b6b)}
.plan-yellow .glow{background:linear-gradient(90deg,var(--yellow),#ffe259)}
.plan-header{margin-bottom:24px}
.plan-tag{display:inline-block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;padding:4px 10px;border-radius:4px;margin-bottom:12px}
.plan-blue .plan-tag{background:rgba(30,144,255,0.15);color:#1e90ff;border:1px solid rgba(30,144,255,0.3)}
.plan-green .plan-tag{background:rgba(0,200,83,0.15);color:#00c853;border:1px solid rgba(0,200,83,0.3)}
.plan-red .plan-tag{background:rgba(217,4,41,0.15);color:#ff4060;border:1px solid rgba(217,4,41,0.3)}
.plan-yellow .plan-tag{background:rgba(255,215,0,0.15);color:var(--yellow);border:1px solid rgba(255,215,0,0.3)}
.plan-name{font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:900;color:#fff;margin-bottom:6px}
.plan-desc{font-size:14px;color:var(--muted);line-height:1.6}
.plan-price-box{margin:20px 0;padding:20px 0;border-top:1px solid rgba(255,255,255,0.06);border-bottom:1px solid rgba(255,255,255,0.06)}
.plan-price{font-family:'Barlow Condensed',sans-serif;font-size:48px;font-weight:900;color:var(--yellow);line-height:1}
.plan-price .cents{font-size:24px;vertical-align:super}
.plan-price .period{font-size:16px;color:var(--muted);font-weight:400}
.plan-features{display:flex;flex-direction:column;gap:10px;margin-bottom:28px}
.plan-feat{display:flex;align-items:flex-start;gap:10px;font-size:14px;color:var(--muted2);line-height:1.5}
.plan-feat i{flex-shrink:0;margin-top:1px}
.plan-blue .plan-feat i{color:#1e90ff}
.plan-green .plan-feat i{color:#00c853}
.plan-red .plan-feat i{color:#ff4060}
.plan-yellow .plan-feat i{color:var(--yellow)}
.plan-feat.inherited{color:var(--muted);font-style:italic;font-size:13px}
.plan-recommended{position:absolute;top:16px;right:16px;background:var(--yellow);color:#000;font-size:10px;font-weight:800;padding:4px 10px;border-radius:20px;text-transform:uppercase;letter-spacing:.5px}

/* ===== COMPARISON TABLE ===== */
#compare{background:var(--dark)}
.compare-table{width:100%;border-collapse:collapse;background:var(--card);border-radius:16px;overflow:hidden;border:1px solid var(--border)}
.compare-table th{background:#111;padding:16px 20px;font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;text-align:center}
.compare-table th:first-child{text-align:left;color:var(--muted2)}
.compare-table th.col-blue{color:#1e90ff}
.compare-table th.col-green{color:#00c853}
.compare-table th.col-red{color:#ff4060}
.compare-table td{padding:14px 20px;font-size:14px;text-align:center;border-top:1px solid rgba(255,255,255,0.04)}
.compare-table td:first-child{text-align:left;color:var(--muted2)}
.compare-table tr:hover td{background:rgba(255,215,0,0.02)}
.compare-table .yes{color:#00c853;font-size:18px}
.compare-table .no{color:rgba(255,255,255,0.2);font-size:18px}
.compare-table .price-row td{background:rgba(255,215,0,0.04);font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:700;color:var(--yellow)}
.compare-table .price-row td:first-child{color:var(--muted)}

/* ===== INFO SECTION ===== */
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.info-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:24px;display:flex;gap:16px}
.info-icon{width:48px;height:48px;border-radius:12px;background:rgba(255,215,0,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.info-icon i{font-size:24px;color:var(--yellow)}
.info-title{font-size:16px;font-weight:700;color:#fff;margin-bottom:6px}
.info-text{font-size:14px;color:var(--muted2);line-height:1.7}

/* ===== TESTIMONIALS ===== */
#testimonials{background:#000}
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.test-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:24px;position:relative}
.test-stars{display:flex;gap:3px;margin-bottom:12px}
.test-stars i{font-size:14px;color:var(--yellow)}
.test-text{font-size:15px;color:var(--muted2);line-height:1.7;margin-bottom:16px;font-style:italic}
.test-text::before{content:'"';font-size:40px;color:rgba(255,215,0,0.15);position:absolute;top:12px;left:16px;font-family:Georgia,serif;line-height:1}
.test-author{display:flex;align-items:center;gap:10px}
.test-av{width:40px;height:40px;border-radius:50%;background:var(--card2);border:2px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.test-name{font-size:14px;font-weight:700;color:#fff}
.test-rank{font-size:12px;color:var(--muted)}

/* ===== FAQ ===== */
#faq{background:var(--dark)}
.faq-list{max-width:800px;margin:0 auto;display:flex;flex-direction:column;gap:12px}
.faq-item{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden}
.faq-q{display:flex;align-items:center;justify-content:space-between;padding:18px 20px;font-size:15px;font-weight:600;color:#fff;transition:color .2s}
.faq-q:hover{color:var(--yellow)}
.faq-q i{font-size:18px;color:var(--yellow);transition:transform .3s;flex-shrink:0}
.faq-a{display:none;padding:0 20px 18px;font-size:14px;color:var(--muted2);line-height:1.8;border-top:1px solid rgba(255,255,255,0.04)}
.faq-item.open .faq-q i{transform:rotate(180deg)}
.faq-item.open .faq-a{display:block}

/* ===== COUNTER ===== */
#counter{background:#000;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.counter-grid{display:flex;justify-content:center;gap:80px;padding:56px 0}
.cnt-item{text-align:center}
.cnt-num{font-family:'Barlow Condensed',sans-serif;font-size:64px;font-weight:900;color:var(--yellow);line-height:1}
.cnt-lbl{font-size:13px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:4px}

/* ===== FOOTER ===== */
footer{background:#000;padding:48px 0;border-top:1px solid rgba(255,255,255,0.04)}
.footer-inner{display:flex;justify-content:space-between;align-items:center}
.footer-logo{font-family:'Barlow Condensed',sans-serif;font-size:24px;font-weight:900;color:#fff}
.footer-logo span{color:var(--yellow)}
.footer-links{display:flex;gap:24px;font-size:14px;color:var(--muted2)}
.footer-links a:hover{color:var(--yellow)}
.copyright{font-size:12px;color:var(--muted);margin-top:24px;text-align:center;padding-top:24px;border-top:1px solid rgba(255,255,255,0.03)}

/* ===== CART SIDEBAR ===== */
.cart-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);z-index:2000;display:none}
.cart-overlay.open{display:block}
.cart-sidebar{position:fixed;top:0;right:-400px;bottom:0;width:400px;background:#0d0d0d;border-left:1px solid var(--border);z-index:2001;transition:right .3s cubic-bezier(0.16,1,0.3,1);padding:32px;display:flex;flex-direction:column}
.cart-sidebar.open{right:0}
.cart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px}
.cart-title{font-family:'Barlow Condensed',sans-serif;font-size:24px;font-weight:900;color:#fff;display:flex;align-items:center;gap:8px}
.cart-close{background:none;border:none;color:var(--muted);font-size:24px}
.cart-items{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:16px;margin-bottom:24px}
.cart-item{background:var(--card);border:1px solid rgba(255,255,255,0.04);border-radius:10px;padding:16px;display:flex;justify-content:space-between;align-items:center;position:relative}
.cart-item-info{display:flex;flex-direction:column;gap:4px}
.cart-item-name{font-size:15px;font-weight:700;color:#fff}
.cart-item-price{font-size:14px;color:var(--yellow);font-weight:600}
.cart-item-remove{background:none;border:none;color:rgba(217,4,41,0.6);font-size:18px}
.cart-item-remove:hover{color:var(--red)}
.cart-empty{text-align:center;color:var(--muted);margin:auto 0;font-size:14px}
.cart-footer{border-top:1px solid rgba(255,255,255,0.06);padding-top:20px}
.cart-total-row{display:flex;justify-content:space-between;font-size:16px;font-weight:700;color:#fff;margin-bottom:20px}
.cart-total-price{color:var(--yellow);font-size:20px;font-family:'Barlow Condensed',sans-serif}

/* ===== AUTH MODAL ===== */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.85);backdrop-filter:blur(6px);z-index:3000;display:none;align-items:center;justify-content:center;padding:24px}
.modal-overlay.open{display:flex}
.modal-box{background:#0d0d0d;border:1px solid var(--border2);border-radius:20px;width:100%;max-width:440px;padding:32px;position:relative;box-shadow:0 20px 50px rgba(0,0,0,0.5)}
.modal-close{position:absolute;top:20px;right:20px;background:none;border:none;color:var(--muted);font-size:20px}
.auth-tabs{display:flex;border-bottom:1px solid rgba(255,255,255,0.06);margin-bottom:24px}
.auth-tab{flex:1;text-align:center;padding:12px;font-size:15px;font-weight:600;color:var(--muted);border-bottom:2px solid transparent;transition:all .2s}
.auth-tab.active{color:var(--yellow);border-color:var(--yellow)}
.form-group{margin-bottom:16px}
.form-label{display:block;font-size:13px;font-weight:500;color:var(--muted2);margin-bottom:6px}
.form-input{width:100%;background:var(--card);border:1px solid rgba(255,215,0,0.1);border-radius:var(--r2);padding:12px 16px;color:#fff;font-family:'Barlow',sans-serif;font-size:14px;outline:none;transition:all .2s}
.form-input:focus{border-color:var(--yellow);box-shadow:0 0 12px rgba(255,215,0,0.1)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}

/* ===== CHECKOUT ===== */
.checkout-layout{display:grid;grid-template-columns:1fr 380px;gap:32px;align-items:flex-start}
.checkout-main{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:32px}
.checkout-title{font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:900;color:#fff;margin-bottom:24px;display:flex;align-items:center;gap:12px;text-transform:uppercase}
.checkout-section{margin-bottom:28px}
.checkout-section-title{font-size:16px;font-weight:700;color:#fff;margin-bottom:16px;display:flex;align-items:center;gap:8px;padding-bottom:8px;border-bottom:1px solid rgba(255,255,255,0.05)}
.checkout-section-title i{color:var(--yellow)}
