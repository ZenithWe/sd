<script>
// ============ BANCO DE DADOS LOCAL (LOCALSTORAGE) EXPANDIDO ============
const DB = {
  get: (k, def)=> JSON.parse(localStorage.getItem('bg_'+k)) || def,
  set: (k, v)=> localStorage.setItem('bg_'+k, JSON.stringify(v)),
  
  users: function(){ return this.get('users', [
    {id:1, name:'Admin BG', email:'admin@bg.com', password:'admin', discord:'admin_bg', isAdmin:true, createdAt:'01/01/2026'},
    {id:2, name:'Kael FN', email:'kael@email.com', password:'123', discord:'kael_unreal', isAdmin:false, createdAt:'05/02/2026'}
  ])},
  addUser: function(u){ const arr=this.users(); arr.push(u); this.set('users', arr); },
  
  plans: function(){ return this.get('plans', [
    {id:1, name:'Plano BASIC', price:'49.90', color:'blue', desc:'Ideal para quem quer começar a organizar sua rotina.', features:['VOD Review de 1 Partida','Acesso ao Servidor VIP Discord','Cargo Exclusivo de Aluno'], active:true},
    {id:2, name:'Plano PRO', price:'149.90', color:'green', desc:'O mais popular. Focado em evolução constante média/alta.', features:['VOD Review de 3 Partidas','Guia Macetes e Rotações Custom','2 Calls de Alinhamento (40min)','Rotina de Treino Customizada'], active:true},
    {id:3, name:'Plano ELITE', price:'299.90', color:'red', desc:'Acompanhamento profissional diário para o topo.', features:['VOD Reviews Ilimitadas (30 dias)','4 Calls Individuais (60min)','Suporte direto via WhatsApp','Prioridade Máxima com os Mentores'], active:true}
  ])},
  savePlans: function(arr){ this.set('plans', arr); },

  // Módulo 2 — Tabelas Adicionais
  categories: function() { return this.get('categories', [
    {slug:'ebooks', name:'E-books e Guias'},
    {slug:'courses', name:'Cursos Gravados'}
  ]);},
  saveCategories: function(arr) { this.set('categories', arr); },

  digitalProducts: function() { return this.get('digitalProducts', [
    {id:101, name:'Ebook: Guia do Early Game Perfeito', category:'ebooks', price:'19.90'},
    {id:102, name:'Curso: Mecânicas Avançadas Piece Control', category:'courses', price:'79.90'}
  ]);},
  saveDigitalProducts: function(arr) { this.set('digitalProducts', arr); },

  siteTexts: function() { return this.get('siteTexts', {
    heroTitle: 'Gameplay',
    heroSubtitle: 'Aprenda as mecânicas, rotações e tomadas de decisão que separam os amadores dos pro players de Fortnite competitive.',
    pixKey: 'financeiro@beginninggame.com',
    discordLink: 'https://discord.gg/beginninggame'
  });},
  saveSiteTexts: function(obj) { this.set('siteTexts', obj); },
  
  orders: function(){ return this.get('orders', []) },
  addOrder: function(o){ const arr=this.orders(); arr.push(o); this.set('orders', arr); },
  saveOrders: function(arr){ this.set('orders', arr); },
  
  currentUser: function(){ return this.get('current_user', null); },
  setUser: function(u){ this.set('current_user', u); }
};

// ============ ESTADO DO CARRINHO VIA SESSIONSTORAGE ============
let cart = JSON.parse(sessionStorage.getItem('bg_cart')) || [];

function saveCart() {
  sessionStorage.setItem('bg_cart', JSON.stringify(cart));
  updateCartUI();
}

// ============ CONTROLE DE ROTAS E DIRECIONAMENTO ============
function showPage(pId) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const target = document.getElementById('page-'+pId);
  if(target) target.classList.add('active');
  window.scrollTo({top:0});
  
  document.querySelectorAll('#navbar .nav-links a').forEach(a=>{
    a.classList.toggle('active', a.getAttribute('href')==='#'+pId || (pId==='home' && a.getAttribute('href').startsWith('#')));
  });

  if(pId === 'client') renderClient();
  if(pId === 'admin') renderAdmin();
}

// ============ INICIALIZAÇÃO DE TEXTOS DO ADMIN EXPANDIDO ============
function applySiteTexts() {
  const texts = DB.siteTexts();
  const titleDisplay = document.getElementById('heroTitleDisplay');
  if(titleDisplay) {
    titleDisplay.innerHTML = `<div class="line1">Evolua seu</div><div class="line2">${texts.heroTitle}</div><div class="line3">Ao Extremo</div>`;
  }
  const subtitleDisplay = document.getElementById('heroSubtitleDisplay');
  if(subtitleDisplay) subtitleDisplay.textContent = texts.heroSubtitle;

  const dLink = document.getElementById('discordSupportLink');
  if(dLink) dLink.href = texts.discordLink;
}

// ============ RENDERIZADOR DE PLANOS (E PRODUTOS DIGITAIS ADICIONAIS) ============
function renderPlans() {
  const container = document.getElementById('plansGrid');
  if(!container) return;
  container.innerHTML = '';

  // Renderiza planos estruturais de mentoria
  DB.plans().filter(p=>p.active).forEach(p=>{
    const card = document.createElement('div');
    card.className = `plan-card plan-${p.color} ${p.name.includes('PRO')?'featured':''}`;
